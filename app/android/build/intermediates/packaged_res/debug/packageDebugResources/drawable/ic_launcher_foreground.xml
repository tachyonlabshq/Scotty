<?xml version="1.0" encoding="utf-8"?>
<!--
  Scotty beam motif: NFC arc waves + lightning bolt
  Teal on dark background — matches ScottyDarkColorScheme
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"

    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer NFC arc (large) -->
    <path
        android:strokeColor="#4DD0E1"
        android:strokeWidth="3.5"
        android:fillColor="@android:color/transparent"
        android:pathData="M28,54 A26,26 0 0,1 54,28" />
    <path
        android:strokeColor="#4DD0E1"
        android:strokeWidth="3.5"
        android:fillColor="@android:color/transparent"
        android:pathData="M80,54 A26,26 0 0,0 54,28" />

    <!-- Middle NFC arc -->
    <path
        android:strokeColor="#80DEEA"
        android:strokeWidth="3"
        android:fillColor="@android:color/transparent"
        android:pathData="M35,54 A19,19 0 0,1 54,35" />
    <path
        android:strokeColor="#80DEEA"
        android:strokeWidth="3"
        android:fillColor="@android:color/transparent"
        android:pathData="M73,54 A19,19 0 0,0 54,35" />

    <!-- Inner NFC arc -->
    <path
        android:strokeColor="#B2EBF2"
        android:strokeWidth="2.5"
        android:fillColor="@android:color/transparent"
        android:pathData="M42,54 A12,12 0 0,1 54,42" />
    <path
        android:strokeColor="#B2EBF2"
        android:strokeWidth="2.5"
        android:fillColor="@android:color/transparent"
        android:pathData="M66,54 A12,12 0 0,0 54,42" />

    <!-- Lightning bolt / beam center -->
    <path
        android:fillColor="#4DD0E1"
        android:pathData="M57,30 L47,54 L55,54 L51,78 L64,50 L56,50 Z" />


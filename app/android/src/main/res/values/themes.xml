<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Opaque window background prevents transparent-pixel screencap artifacts.
         Scotty teal #E0F7FA shows immediately before Compose draws. -->
    <style name="Theme.LocalSend" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/scotty_background</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme — extends SplashScreen with Scotty branding -->
    <style name="Theme.Scotty.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/scotty_background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
        <item name="postSplashScreenTheme">@style/Theme.LocalSend</item>
    </style>
</resources>
